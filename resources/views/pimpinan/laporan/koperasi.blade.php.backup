                                <tr>
                                    <td>No. Telepon</td>
                                    <td>:</td>
                                    <td>📞 ${k.no_telepon || '-'}</td>
                                </tr>
                                <tr>
                                    <td>Email</td>
                                    <td>:</td>
                                    <td>✉️ ${k.email || '-'}</td>
                                </tr>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="section">
                <div class="section-header">
                    <h4>📍 INFORMASI LOKASI</h4>
                </div>
                <div class="section-body">
                    <table class="info-table">
                        <tr>
                            <td>Distrik</td>
                            <td>:</td>
                            <td>${k.distrik || '-'}</td>
                        </tr>
                        <tr>
                            <td>Kampung</td>
                            <td>:</td>
                            <td>${k.kampung || '-'}</td>
                        </tr>
                        <tr>
                            <td>Alamat Lengkap</td>
                            <td>:</td>
                            <td>${k.alamat || '-'}</td>
                        </tr>
                    </table>
                </div>
            </div>
            
            <div class="section">
                <div class="section-header">
                    <h4>ℹ️ INFORMASI TAMBAHAN</h4>
                </div>
                <div class="section-body">
                    <table class="info-table">
                        <tr>
                            <td>Tanggal Pendaftaran</td>
                            <td>:</td>
                            <td>📅 ${k.created_at || '-'}</td>
                        </tr>
                        <tr>
                            <td>Terakhir Diupdate</td>
                            <td>:</td>
                            <td>🕐 ${k.updated_at || '-'}</td>
                        </tr>
                        ${k.verified_by ? `
                        <tr>
                            <td>Diverifikasi Oleh</td>
                            <td>:</td>
                            <td>✅ ${k.verified_by}</td>
                        </tr>
                        ` : ''}
                        ${k.verified_at ? `
                        <tr>
                            <td>Tanggal Verifikasi</td>
                            <td>:</td>
                            <td>📅 ${k.verified_at}</td>
                        </tr>
                        ` : ''}
                    </table>
                    ${k.catatan_verifikasi ? `
                    <div class="alert-box">
                        <strong>📝 Catatan Verifikasi:</strong><br>
                        ${k.catatan_verifikasi}
                    </div>
                    ` : ''}
                </div>
            </div>
            
            <div class="footer">
                <p><strong>Dokumen ini dicetak pada:</strong> ${new Date().toLocaleDateString('id-ID', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' })} WIT</p>
                <p style="margin-top: 5px;">© ${new Date().getFullYear()} DISPERINDAGKOP Kabupaten Tolikara - Semua Hak Dilindungi</p>
            </div>
        </body>
        </html>
    `;
    
    printWindow.document.write(printContent);
    printWindow.document.close();
}
</script>

@endsection
