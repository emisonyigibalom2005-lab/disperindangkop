    @php
        $periodeBuka = \App\Models\PeriodePendaftaran::where('status', 'aktif')
            ->where('tanggal_mulai', '<=', now())
            ->where('tanggal_selesai', '>=', now())
            ->first();
        
        // Cek kelengkapan data
        $dataKosong = [];
        if(empty($anggota->nik)) $dataKosong[] = 'NIK';
        if(empty($anggota->tempat_lahir)) $dataKosong[] = 'Tempat Lahir';
        if(empty($anggota->tanggal_lahir)) $dataKosong[] = 'Tanggal Lahir';
        if(empty($anggota->jenis_kelamin)) $dataKosong[] = 'Jenis Kelamin';
        if(empty($anggota->agama)) $dataKosong[] = 'Agama';
        if(empty($anggota->no_hp)) $dataKosong[] = 'No. HP';
        if(empty($anggota->alamat_lengkap)) $dataKosong[] = 'Alamat';
        if(empty($anggota->nama_usaha)) $dataKosong[] = 'Nama Usaha';
        if(empty($anggota->bidang_usaha)) $dataKosong[] = 'Bidang Usaha';
        if(empty($anggota->foto)) $dataKosong[] = 'Foto';
        
        $persenKelengkapan = 100 - (count($dataKosong) * 10);
        if($persenKelengkapan < 0) $persenKelengkapan = 0;
        
        $needsUpdate = count($dataKosong) > 0 || $anggota->status === 'Ditolak';
    @endphp

