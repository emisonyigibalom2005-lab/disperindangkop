                    flex-shrink: 0;
                    width: 85px;
                    height: 85px;
                }
                
                .header-logo img {
                    width: 100%;
                    height: 100%;
                    object-fit: contain;
                }
                
                .header-text {
                    flex: 1;
                    text-align: center;
                }
                
                .header-text h1 {
                    color: #1a3a6e;
                    font-size: 20px;
                    margin-bottom: 5px;
                    font-weight: bold;
                    text-transform: uppercase;
                }
                
                .header-text h2 {
                    color: #1a3a6e;
                    font-size: 16px;
                    margin-bottom: 8px;
                    font-weight: bold;
                    text-transform: uppercase;
                }
                
                .header-text p {
                    color: #666;
                    font-size: 11px;
                    margin: 2px 0;
                }
                
                .header-logo-right {
                    flex-shrink: 0;
                    width: 85px;
                    height: 85px;
                }
                
                .header-logo-right img {
                    width: 100%;
                    height: 100%;
                    object-fit: contain;
                }
                
                .title {
                    text-align: center;
                    margin: 20px 0;
                    padding: 12px;
                    background: linear-gradient(135deg, #667eea, #764ba2);
                    color: white;
